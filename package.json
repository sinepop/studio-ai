{
  "name": "gravuresse",
  "version": "1.4.0",
  "description": "Gravuresse - AI Creative Design Desktop App",
  "author": "Gravuresse",
  "license": "MIT",
  "main": "dist/main/main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "preview": "electron-vite preview --config electron.vite.config.mjs",
    "package": "electron-vite build --config electron.vite.config.mjs && electron-builder --win",
    "package:dir": "electron-vite build --config electron.vite.config.mjs && electron-builder --win dir --publish=never"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.5"
  }
}
